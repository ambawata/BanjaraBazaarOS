# --- Dependencies ---
/vendor/
**/node_modules/

# --- Env / secrets ---
.env
.env.*
!.env.example

# --- Build / cache output ---
**/dist/
**/.vite/
**/.turbo/
**/build/
*.log

# --- Storage runtime contents (track structure via .gitkeep, ignore content) ---
/storage/uploads/*
/storage/qr/*
/storage/exports/*
/storage/logs/*
/storage/cache/*
/storage/temp/*
!/storage/**/.gitkeep

# --- Legacy / misc ignores ---
/backups/

# --- Editor / OS ---
/.idea/
/.vscode/
/.claude/*
!/.claude/settings.json
.DS_Store
Thumbs.db

# --- Archives (allow /database/*.sql to be tracked) ---
*.zip

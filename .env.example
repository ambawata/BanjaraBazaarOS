# BanjaraBazaarOS — Backend environment template
# Copy to .env (never commit). All keys here are placeholders.

APP_ENV=development
APP_DEBUG=true
APP_URL=https://banjarabazaar.online
APP_TIMEZONE=Asia/Kolkata

# --- Database (MySQL on Hostinger) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=banjarabazaar
DB_USER=
DB_PASS=

# --- Auth ---
JWT_SECRET=
JWT_TTL_MINUTES=60
SESSION_LIFETIME_MINUTES=120

# --- Storage paths (relative to repo root) ---
STORAGE_PATH=/storage
UPLOADS_PATH=/storage/uploads
QR_PATH=/storage/qr
EXPORTS_PATH=/storage/exports
LOGS_PATH=/storage/logs
CACHE_PATH=/storage/cache
TEMP_PATH=/storage/temp

# --- API ---
API_VERSION=v1
API_RATE_LIMIT_PER_MINUTE=60

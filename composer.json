{
    "name": "banjarabazaar/os",
    "description": "BanjaraBazaarOS — unified web + PWA backend (PHP 8 / MySQL).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "firebase/php-jwt": "^6.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Backend\\Core\\": "backend/core/",
            "Backend\\Config\\": "backend/config/",
            "Backend\\Middleware\\": "backend/middleware/",
            "Backend\\Services\\": "backend/services/",
            "Backend\\Models\\": "backend/models/",
            "Backend\\Helpers\\": "backend/helpers/",
            "Backend\\Api\\V1\\": "backend/api/v1/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "migrate": "php scripts/migrate.php",
        "serve": "php -S 127.0.0.1:8000 -t public"
    }
}